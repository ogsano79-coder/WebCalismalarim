@page
@model soru1.Pages.Index1Model
@{
    ViewData["Title"] = "Toplama ve Çarpma Hesaplayıcı";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white text-center">
                    <h3 class="card-title mb-0">Sayı Hesaplayıcı</h3>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="Sayi1" class="form-label">1. Sayı:</label>
                            <input type="number" step="any" class="form-control" asp-for="Sayi1" required />
                            <span asp-validation-for="Sayi1" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Sayi2" class="form-label">2. Sayı:</label>
                            <input type="number" step="any" class="form-control" asp-for="Sayi2" required />
                            <span asp-validation-for="Sayi2" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Hesapla</button>
                    </form>

                    @if (Model.IsPost && Model.Toplam.HasValue && Model.Carpim.HasValue)
                    {
                        <div class="mt-4 border-top pt-3">
                            <h5 class="text-center mb-3 text-secondary">Hesaplama Sonuçları</h5>
                            
                            <div class="alert alert-info text-center fw-bold" role="alert">
                                Sayıların Toplamı: @Model.Toplam
                            </div>
                            
                            <div class="alert alert-warning text-center fw-bold" role="alert">
                                Sayıların Çarpımı: @Model.Carpim
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>